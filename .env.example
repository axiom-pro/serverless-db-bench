# Copy to .env and fill. Run scripts with: node --env-file=.env bin/<script>.mjs
# SAFETY: use free-tier accounts with NO card / spend cap ON / overages OFF.

# Which region this runner sits in (tag only; you deploy the runner per region).
REGION=tokyo            # tokyo | singapore | frankfurt | virginia | local

# --- Supabase (Postgres) ---
# Direct (Session) connection string and the Supavisor pooler string (Transaction mode).
SUPABASE_DATABASE_URL=postgresql://postgres:PW@db.PROJECT.supabase.co:5432/postgres?sslmode=require
SUPABASE_POOLER_URL=postgresql://postgres.PROJECT:PW@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# --- Neon ---
NEON_DIRECT_URL=postgresql://USER:PW@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# Neon HTTP serverless driver uses the same URL:
NEON_DATABASE_URL=postgresql://USER:PW@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# --- Turso (libSQL) ---
TURSO_DATABASE_URL=libsql://DBNAME-ORG.turso.io
TURSO_AUTH_TOKEN=xxxxx

# --- Cloudflare D1 (REST API) ---
CF_ACCOUNT_ID=xxxxxxxx
CF_D1_DATABASE_ID=xxxxxxxx
CF_API_TOKEN=xxxxxxxx    # token with D1:Edit

# --- Sampling ---
WARM_SAMPLES=200
TRANSPORT_SAMPLES=30
GAP_MS=50
SEED_ROWS=10000

# --- Destructive test gate (Phase B). Set ONLY after verifying no billing risk. ---
# BILLING_SAFE=confirmed
